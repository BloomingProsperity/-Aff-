---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '专业的海外银行卡科普与推荐，手把手教你开通 Bybit、SafePal、Pokepay、Roogoo 等虚拟卡' } = Astro.props;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : null;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-Hans">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | 卡研所</title>
  <meta name="description" content={description} />
  {canonicalURL && <link rel="canonical" href={canonicalURL} />}
  <meta property="og:title" content={`${title} | 卡研所`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body style="background:var(--color-bg); min-height:100vh;">

  <!-- Navigation -->
  <header class="site-header">
    <div class="nav-inner">

      <!-- Logo -->
      <a href="/" class="nav-logo" aria-label="卡研所首页">
        卡<span class="glow">研</span>所
      </a>

      <!-- Desktop nav -->
      <nav class="nav-desktop" aria-label="主导航">
        <a href="/cards" class={`nav-link${currentPath.startsWith('/cards') ? ' active' : ''}`}>银行卡推荐</a>
        <a href="/shop"  class={`nav-link${currentPath === '/shop' ? ' active' : ''}`}>商店</a>
        <a href="/contact" class={`nav-link${currentPath === '/contact' ? ' active' : ''}`}>联系我</a>
        <a href="/contact" class="btn-cta" style="font-size:0.82rem; padding:9px 18px;">加入社群</a>
      </nav>

      <!-- Mobile hamburger -->
      <button id="hamburger-btn" class="hamburger-label" aria-label="打开菜单" aria-expanded="false" style="display:none; cursor:pointer; padding:8px; flex-direction:column; gap:5px; background:none; border:none;">
        <span style="display:block; width:22px; height:2px; background:var(--color-ink); border-radius:2px; transition:transform 0.2s;"></span>
        <span style="display:block; width:22px; height:2px; background:var(--color-ink); border-radius:2px; transition:opacity 0.2s;"></span>
        <span style="display:block; width:22px; height:2px; background:var(--color-ink); border-radius:2px; transition:transform 0.2s;"></span>
      </button>
    </div>

    <!-- Mobile nav menu -->
    <nav id="nav-menu-mobile" aria-label="移动端导航">
      <a href="/cards" class={`nav-link${currentPath.startsWith('/cards') ? ' active' : ''}`} style="padding:10px 0; font-size:1rem;">银行卡推荐</a>
      <a href="/shop"  class={`nav-link${currentPath === '/shop' ? ' active' : ''}`} style="padding:10px 0; font-size:1rem;">商店</a>
      <a href="/contact" class={`nav-link${currentPath === '/contact' ? ' active' : ''}`} style="padding:10px 0; font-size:1rem;">联系我</a>
      <a href="/contact" class="btn-cta" style="font-size:0.88rem; padding:11px 20px; margin-top:8px; text-align:center;">加入社群</a>
    </nav>
  </header>

  <style>
    .site-header {
      border-bottom: 1px solid var(--color-border);
      background: rgba(10, 15, 30, 0.88);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 62px;
    }
    .nav-logo {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 1.3rem;
      color: var(--color-ink);
      text-decoration: none;
      letter-spacing: -0.02em;
    }
    .nav-desktop {
      display: flex;
      gap: 28px;
      align-items: center;
    }

    /* Mobile hamburger */
    #nav-menu-mobile {
      display: none;
      flex-direction: column;
      padding: 12px 24px 20px;
      background: rgba(10, 15, 30, 0.97);
      border-top: 1px solid var(--color-border);
    }
    #nav-menu-mobile.open {
      display: flex;
    }

    @media (max-width: 768px) {
      .nav-desktop { display: none; }
      .hamburger-label { display: flex !important; }
    }
  </style>

  <!-- Main content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <hr class="section-divider" />
    <div class="footer-inner">
      <div class="footer-col">
        <div class="footer-logo">卡<span class="glow">研</span>所</div>
        <p class="footer-desc">专注海外银行卡科普与推广，帮助华人用户找到最适合的虚拟卡解决方案。</p>
      </div>
      <div class="footer-col">
        <div class="footer-heading">快速导航</div>
        <nav class="footer-links">
          <a href="/cards">银行卡推荐</a>
          <a href="/shop">礼品卡商店</a>
          <a href="/contact">联系我</a>
        </nav>
      </div>
      <div class="footer-col">
        <div class="footer-heading">联系方式</div>
        <div class="footer-links">
          <a href="https://t.me/Whohaoe" target="_blank" style="color:var(--color-tg); font-weight:600;">Telegram 频道</a>
          <span style="color:var(--color-ink-2);">微信：扫码关注</span>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2025 卡研所 · 部分链接为推广链接，不影响内容独立性</span>
      <span style="color:var(--color-ink-3);">用心为华人用户打造</span>
    </div>
  </footer>

  <style>
    .site-footer {
      margin-top: 100px;
      padding: 0 24px 40px;
    }
    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 48px 0 40px;
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 48px;
    }
    @media (max-width: 768px) {
      .footer-inner { grid-template-columns: 1fr; gap: 32px; }
    }
    .footer-logo {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 1.2rem;
      margin-bottom: 12px;
    }
    .footer-desc {
      font-size: 0.85rem;
      color: var(--color-ink-2);
      line-height: 1.7;
      margin: 0;
    }
    .footer-heading {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-ink-3);
      margin-bottom: 16px;
    }
    .footer-links {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .footer-links a {
      font-size: 0.88rem;
      color: var(--color-ink-2);
      transition: color 0.15s;
    }
    .footer-links a:hover { color: var(--color-primary); }
    .footer-bottom {
      max-width: 1200px;
      margin: 0 auto;
      padding-top: 24px;
      border-top: 1px solid var(--color-border);
      font-size: 0.8rem;
      color: var(--color-ink-2);
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }
  </style>

  <!-- Floating social buttons -->
  <div class="float-btns">

    <!-- Telegram -->
    <a href="https://t.me/Whohaoe" target="_blank" title="加入 Telegram 群" class="float-btn float-btn-tg">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8l-1.68 7.93c-.12.56-.45.7-.92.43l-2.54-1.87-1.22 1.18c-.14.14-.26.26-.52.26l.19-2.63 4.8-4.34c.21-.19-.05-.29-.32-.1L7.83 14.8l-2.5-.78c-.54-.17-.55-.54.12-.8l9.77-3.77c.45-.17.85.11.42.35z"/>
      </svg>
    </a>

    <!-- WeChat -->
    <div class="float-btn-wrap" title="扫码加微信">
      <div class="float-btn float-btn-wechat">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
          <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.295.295a.328.328 0 0 0 .186-.059l2.114-1.25a.59.59 0 0 1 .522-.025c.89.287 1.855.44 2.855.44 3.197 0 6.01-1.553 7.404-3.846a6.06 6.06 0 0 1-.295-.018c-3.795-.025-6.87-2.87-6.87-6.407 0-.283.022-.562.063-.836A7.453 7.453 0 0 0 8.691 2.188zm-2.56 3.99a.892.892 0 1 1 0 1.784.892.892 0 0 1 0-1.784zm5.12 0a.892.892 0 1 1 0 1.784.892.892 0 0 1 0-1.784zM24 13.64c0-3.44-3.282-6.23-7.328-6.23-4.046 0-7.329 2.79-7.329 6.23 0 3.44 3.283 6.23 7.329 6.23.878 0 1.717-.13 2.496-.365a.496.496 0 0 1 .437.021l1.747 1.033a.278.278 0 0 0 .154.049.245.245 0 0 0 .245-.245c0-.06-.024-.118-.04-.176l-.322-1.222a.495.495 0 0 1 .176-.551C23.117 17.453 24 15.644 24 13.64zm-9.718-.148a.74.74 0 1 1 0-1.48.74.74 0 0 1 0 1.48zm4.777 0a.74.74 0 1 1 0-1.48.74.74 0 0 1 0 1.48z"/>
        </svg>
      </div>
      <!-- QR popup -->
      <div class="wechat-popup">
        <div class="wechat-qr-placeholder">
          微信二维码<br/>替换此处
        </div>
        <div class="wechat-popup-label">扫码加我微信</div>
      </div>
    </div>
  </div>

  <style>
    .float-btns {
      position: fixed;
      right: 20px;
      bottom: 80px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      z-index: 200;
    }
    .float-btn {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.18s, box-shadow 0.18s;
      cursor: pointer;
    }
    .float-btn:hover { transform: scale(1.12); }
    .float-btn-tg {
      background: var(--color-tg);
      box-shadow: 0 4px 16px rgba(0, 136, 204, 0.45);
    }
    .float-btn-tg:hover { box-shadow: 0 6px 24px rgba(0, 136, 204, 0.6); }
    .float-btn-wechat {
      background: var(--color-wechat);
      box-shadow: 0 4px 16px rgba(7, 193, 96, 0.45);
    }
    .float-btn-wechat:hover { box-shadow: 0 6px 24px rgba(7, 193, 96, 0.6); }
    .float-btn-wrap {
      position: relative;
    }
    .float-btn-wrap:hover .wechat-popup { display: block; }
    .wechat-popup {
      display: none;
      position: absolute;
      right: 58px;
      bottom: 0;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 14px;
      padding: 16px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
      width: 160px;
      text-align: center;
    }
    .wechat-qr-placeholder {
      width: 128px;
      height: 128px;
      background: var(--color-surface-2);
      border-radius: 8px;
      margin: 0 auto 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.72rem;
      color: var(--color-ink-3);
      line-height: 1.5;
    }
    .wechat-popup-label {
      font-size: 0.75rem;
      color: var(--color-ink-2);
      font-weight: 600;
    }
  </style>

  <script>
    // 复制时自动附加来源声明
    const btn = document.getElementById('hamburger-btn');
    const menu = document.getElementById('nav-menu-mobile');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(open));
      });
    }

    document.addEventListener('copy', function(e) {
      const sel = window.getSelection ? window.getSelection().toString() : '';
      if (sel.length > 20) {
        const attr = '\n\n——\n来源：卡研所 https://kayanso.com\n未经授权禁止转载';
        try {
          e.clipboardData.setData('text/plain', sel + attr);
          e.preventDefault();
        } catch(_) {}
      }
    });
  </script>
</body>
</html>
