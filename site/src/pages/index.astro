---
import Layout from '../layouts/Layout.astro';
import { cards } from '../data/cards';

const featuredCards = cards.slice(0, 6);
---

<Layout title="首页" description="专业海外银行卡科普与推荐，手把手教你开通 Bybit、SafePal、Pokepay 等虚拟卡，大陆用户可用">

  <!-- Hero -->
  <section class="hero grid-bg">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="tag" style="margin-bottom:20px;">华人虚拟卡导航</div>
        <h1 class="hero-title">
          找到最适合你的<br/>
          <span class="glow">海外银行卡</span>
        </h1>
        <p class="hero-sub">
          深度测评 {cards.length} 张主流虚拟卡，手把手教程 + 避坑指南。大陆用户、海外华人都能找到适合自己的方案。
        </p>
        <div class="hero-ctas">
          <a href="/cards" class="btn-cta">查看所有推荐 →</a>
          <a href="/contact" class="btn-outline">加入社群</a>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="hero-stats">
        {[
          { n: `${cards.length}张`, label: '深度测评卡片' },
          { n: '100%', label: '亲测真实开通' },
          { n: '免费', label: '所有教程免费' },
        ].map(s => (
          <div class="stat-item">
            <div class="stat-num glow">{s.n}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Decorative radial glow -->
    <div class="hero-glow-orb hero-glow-1"></div>
    <div class="hero-glow-orb hero-glow-2"></div>
  </section>

  <style>
    .hero {
      position: relative;
      overflow: hidden;
      padding: 100px 24px 80px;
      border-bottom: 1px solid var(--color-border);
    }
    .hero-glow-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
      z-index: 0;
    }
    .hero-glow-1 {
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(0, 212, 255, 0.12) 0%, transparent 70%);
      top: -120px; left: -100px;
    }
    .hero-glow-2 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(123, 47, 255, 0.10) 0%, transparent 70%);
      bottom: -80px; right: -60px;
    }
    .hero-inner {
      position: relative;
      z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
    }
    .hero-content { max-width: 680px; }
    .hero-title {
      font-size: clamp(2.2rem, 5.5vw, 3.6rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.12;
      margin-bottom: 20px;
    }
    .hero-sub {
      font-size: 1.05rem;
      color: var(--color-ink-2);
      max-width: 520px;
      margin-bottom: 36px;
      line-height: 1.8;
    }
    .hero-ctas {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, auto);
      gap: 0;
      margin-top: 64px;
      max-width: 520px;
    }
    .stat-item {
      padding: 16px 28px 16px 0;
      border-right: 1px solid var(--color-border);
      margin-right: 28px;
    }
    .stat-item:last-child {
      border-right: none;
      margin-right: 0;
    }
    .stat-num {
      font-family: var(--font-display);
      font-size: 1.9rem;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 4px;
    }
    .stat-label {
      font-size: 0.8rem;
      color: var(--color-ink-2);
    }
    @media (max-width: 600px) {
      .hero { padding: 72px 20px 60px; }
      .hero-stats { grid-template-columns: repeat(3, 1fr); gap: 0; }
      .stat-item { padding: 16px 0; margin-right: 0; border-right: none; border-bottom: 1px solid var(--color-border); }
      .stat-item:last-child { border-bottom: none; }
    }
  </style>

  <!-- Card grid -->
  <section class="cards-section">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">精选推荐</h2>
        <a href="/cards" class="btn-outline" style="font-size:0.84rem; padding:8px 16px;">查看全部 →</a>
      </div>

      <div class="cards-grid">
        {featuredCards.map(card => (
          <a href={`/cards/${card.slug}`} class="card card-item" style="text-decoration:none;">
            <!-- Card header with accent color -->
            <div class="card-head" style={`--card-color: ${card.color};`}>
              <div class="card-head-top">
                <div>
                  {card.tag && <span class="tag" style="margin-bottom:8px; display:inline-block;">{card.tag}</span>}
                  <div class="card-name">{card.name}</div>
                  <div class="card-network" style={`color:${card.color};`}>{card.network}</div>
                </div>
                <div class="card-rating-wrap">
                  <div class="card-rating">{card.rating}</div>
                  <div class="card-rating-sub">/ 5.0</div>
                </div>
              </div>
            </div>

            <!-- Card body -->
            <div class="card-body">
              <p class="card-tagline">{card.tagline}</p>

              <div class="card-stats">
                {[
                  { label: '费用', val: card.fee },
                  { label: '返现', val: card.cashback },
                  { label: '地区', val: card.regions.split('（')[0] },
                ].map(item => (
                  <div class="card-stat">
                    <div class="card-stat-label">{item.label}</div>
                    <div class="card-stat-val">{item.val}</div>
                  </div>
                ))}
              </div>

              <!-- AI badges -->
              <div class="card-ai-badges">
                {[
                  { name: 'ChatGPT', s: card.ai.chatgpt },
                  { name: 'Claude',  s: card.ai.claude },
                  { name: 'MJ',      s: card.ai.midjourney },
                ].map(a => (
                  <span class={`ai-badge ai-badge-${a.s === '✅' ? 'ok' : a.s === '⚠️' ? 'warn' : 'no'}`}>
                    {a.s} {a.name}
                  </span>
                ))}
              </div>

              <div class="card-footer-row">
                <span class="card-tutorial-link">查看教程 →</span>
                <span class="btn-cta" style="font-size:0.78rem; padding:7px 14px;">立即申请</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div style="text-align:center; margin-top:48px;">
        <a href="/cards" class="btn-cta" style="font-size:0.95rem; padding:14px 36px;">查看全部 {cards.length} 张卡 →</a>
      </div>
    </div>
  </section>

  <style>
    .cards-section {
      padding: 80px 24px;
    }
    .section-inner {
      max-width: 1200px;
      margin: 0 auto;
    }
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 32px;
    }
    .section-title {
      font-size: 1.5rem;
      font-weight: 800;
      margin: 0;
    }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }
    .card-item {
      --card-color: #00D4FF;
    }
    .card-item:hover {
      border-color: var(--card-color) !important;
      box-shadow: 0 0 28px color-mix(in srgb, var(--card-color) 20%, transparent), 0 4px 24px rgba(0,0,0,0.4) !important;
    }
    .card-head {
      background: color-mix(in srgb, var(--card-color) 8%, var(--color-surface));
      border-bottom: 1px solid color-mix(in srgb, var(--card-color) 20%, transparent);
      padding: 20px 20px 16px;
    }
    .card-head-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }
    .card-name {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.05rem;
      color: var(--color-ink);
    }
    .card-network {
      font-size: 0.75rem;
      font-weight: 700;
      margin-top: 2px;
    }
    .card-rating-wrap { text-align: right; }
    .card-rating {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 1.6rem;
      color: var(--color-ink);
      line-height: 1;
    }
    .card-rating-sub {
      font-size: 0.7rem;
      color: var(--color-ink-3);
    }
    .card-body { padding: 16px 20px 20px; }
    .card-tagline {
      font-size: 0.88rem;
      color: var(--color-ink-2);
      margin: 0 0 16px;
      line-height: 1.6;
    }
    .card-stats {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 8px;
      margin-bottom: 16px;
    }
    .card-stat {
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      padding: 8px;
      text-align: center;
    }
    .card-stat-label {
      font-size: 0.66rem;
      color: var(--color-ink-3);
      margin-bottom: 3px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .card-stat-val {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--color-ink);
    }
    .card-ai-badges {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }
    .ai-badge {
      font-size: 0.7rem;
      font-weight: 700;
      padding: 2px 9px;
      border-radius: 100px;
      border: 1px solid;
    }
    .ai-badge-ok  { border-color: rgba(16,185,129,0.4); background: rgba(16,185,129,0.08); color: #34D399; }
    .ai-badge-warn { border-color: rgba(245,158,11,0.4); background: rgba(245,158,11,0.08); color: #FCD34D; }
    .ai-badge-no  { border-color: rgba(239,68,68,0.4); background: rgba(239,68,68,0.08); color: #F87171; }
    .card-footer-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .card-tutorial-link {
      font-size: 0.82rem;
      color: var(--color-primary);
      font-weight: 600;
    }
    @media (max-width: 600px) {
      .section-header { flex-direction: column; align-items: flex-start; gap: 12px; }
      .cards-grid { grid-template-columns: 1fr; }
    }
  </style>

  <!-- Why section -->
  <section class="why-section grid-bg">
    <hr class="section-divider" />
    <div class="why-inner">
      <div class="why-header">
        <div class="tag" style="margin-bottom:16px;">使用场景</div>
        <h2 class="why-title">为什么需要海外银行卡？</h2>
        <p class="why-sub">
          订阅 ChatGPT / Midjourney / Netflix，海淘购物，USDT 出金日常消费，建立海外信用记录……这些场景都需要一张可靠的境外卡。
        </p>
      </div>

      <div class="why-grid">
        {[
          { icon:'🤖', title:'AI 订阅',   desc:'ChatGPT Plus、Midjourney、Claude Pro', accent:'#00D4FF' },
          { icon:'🎬', title:'流媒体',    desc:'Netflix、YouTube Premium、Spotify',   accent:'#7B2FFF' },
          { icon:'💸', title:'USDT 出金', desc:'加密货币换成日常可消费余额',           accent:'#10B981' },
          { icon:'🌍', title:'跨境购物',  desc:'Amazon、eBay、海外独立站',            accent:'#F59E0B' },
        ].map(item => (
          <div class="why-card" style={`--accent: ${item.accent};`}>
            <div class="why-icon">{item.icon}</div>
            <div class="why-card-title">{item.title}</div>
            <div class="why-card-desc">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>
    <hr class="section-divider" />
  </section>

  <style>
    .why-section {
      padding: 80px 24px;
      position: relative;
    }
    .why-inner {
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
    }
    .why-title {
      font-size: 1.8rem;
      margin-bottom: 14px;
    }
    .why-sub {
      color: var(--color-ink-2);
      max-width: 580px;
      margin: 0 auto 40px;
      line-height: 1.8;
    }
    .why-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      text-align: left;
    }
    .why-card {
      --accent: #00D4FF;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 14px;
      padding: 24px 20px;
      transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
      position: relative;
      overflow: hidden;
    }
    .why-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--accent);
      opacity: 0.7;
    }
    .why-card:hover {
      border-color: color-mix(in srgb, var(--accent) 40%, transparent);
      box-shadow: 0 0 20px color-mix(in srgb, var(--accent) 12%, transparent);
      transform: translateY(-2px);
    }
    .why-icon {
      font-size: 1.7rem;
      margin-bottom: 12px;
    }
    .why-card-title {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.95rem;
      margin-bottom: 6px;
      color: var(--color-ink);
    }
    .why-card-desc {
      font-size: 0.82rem;
      color: var(--color-ink-2);
      line-height: 1.6;
    }
    @media (max-width: 600px) {
      .why-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>

  <!-- Community CTA -->
  <section class="cta-section">
    <div class="cta-inner">
      <div class="cta-glow"></div>
      <h2 class="cta-title">有问题？加入我们的社群</h2>
      <p class="cta-sub">200+ 华人用户，每日分享最新开卡攻略、优惠活动和避坑经验</p>
      <div class="cta-btns">
        <a href="https://t.me/Whohaoe" target="_blank" class="cta-btn cta-btn-tg">
          加入 Telegram 群
        </a>
        <a href="/contact" class="cta-btn cta-btn-wechat">
          加微信
        </a>
      </div>
    </div>
  </section>

  <style>
    .cta-section {
      padding: 100px 24px;
      text-align: center;
    }
    .cta-inner {
      max-width: 640px;
      margin: 0 auto;
      position: relative;
    }
    .cta-glow {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 400px;
      height: 200px;
      background: radial-gradient(ellipse, rgba(123, 47, 255, 0.12) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }
    .cta-title {
      font-size: 1.8rem;
      margin-bottom: 12px;
      position: relative;
      z-index: 1;
    }
    .cta-sub {
      color: var(--color-ink-2);
      margin-bottom: 36px;
      position: relative;
      z-index: 1;
    }
    .cta-btns {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      position: relative;
      z-index: 1;
    }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 28px;
      border-radius: 9px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.9rem;
      text-decoration: none;
      transition: transform 0.18s, box-shadow 0.18s, opacity 0.18s;
    }
    .cta-btn:hover { transform: translateY(-1px); opacity: 0.9; }
    .cta-btn-tg {
      background: var(--color-tg);
      color: white;
      box-shadow: 0 4px 20px rgba(0, 136, 204, 0.35);
    }
    .cta-btn-tg:hover { box-shadow: 0 6px 28px rgba(0, 136, 204, 0.5); }
    .cta-btn-wechat {
      background: var(--color-wechat);
      color: white;
      box-shadow: 0 4px 20px rgba(7, 193, 96, 0.3);
    }
    .cta-btn-wechat:hover { box-shadow: 0 6px 28px rgba(7, 193, 96, 0.45); }
  </style>

</Layout>
